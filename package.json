  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run lint",
      "git add ."
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Toskysun/MusicFree.git"
  },
  "main": "index.js",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "crypto-js",
          "react-native-background-timer",
          "react-native-fast-image",
          "react-native-fs",
          "react-native-track-player"
        ],
        "listUnknownPackages": false
      }
    }
